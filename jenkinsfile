pipeline {
    agent any

    environment {
        IMAGE_NAME = "dan-c123realtime-app"
        CONTAINER_NAME = "dan-c123realtime-container"
        DOCKER_PORT = "80"
        HOST_PORT = "8083"
        WORKDIR = "C123realtime_drawing"
    }

    stages {
        stage('Clone the Repo') {
            steps {
                echo '🔄 Cloning the repository...'
                deleteDir()
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/feature']],
                    userRemoteConfigs: [[
                        url: 'git@github.com:thani2808/Dev-C123realtime_drawing-Danish-proj.git',
                        credentialsId: 'private-key-jenkins'
                    ]]
                ])
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${WORKDIR}") {
                    script {
                        echo '🔍 Checking for Dockerfile...'
                        if (!fileExists('Dockerfile')) {
                            error "❌ Dockerfile not found in ${WORKDIR}/"
                        }

                        echo '🐳 Building Docker image (Windows)...'
                        bat "docker build -t ${IMAGE_NAME} ."
                    }
                }
            }
        }

        stage('Stop and Remove Old Container') {
            steps {
                script {
                    echo "🧹 Cleaning up old container if exists..."
                    bat """
                        docker stop ${CONTAINER_NAME} || exit 0
                        docker rm ${CONTAINER_NAME} || exit 0
                    """
                }
            }
        }

        stage('Run Docker Container') {
            steps {
                echo "🚀 Running container on port ${HOST_PORT}"
                bat "docker run -d --name ${CONTAINER_NAME} -p ${HOST_PORT}:${DOCKER_PORT} ${IMAGE_NAME}"
            }
        }

        stage('Success Confirmation') {
            steps {
                echo '✅ Nginx container deployed successfully!'
            }
        }
    }

    post {
        failure {
            echo '❌ Pipeline failed. Check logs for issues.'
        }
        always {
            echo '📦 Pipeline complete.'
        }
    }
}
